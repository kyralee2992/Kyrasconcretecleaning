NEXT_PUBLIC_WEB3FORMS_KEY=your_access_key_here
NEXT_PUBLIC_SITE_URL=https://yourdomain.com

# Firebase Admin SDK service account for snapbid-eb2c8, base64-encoded.
# Generate: Firebase Console → Project Settings → Service Accounts →
#           Generate New Private Key, then: base64 < key.json | tr -d '\n'
# Used server-side only (Next.js route handlers running on Vercel).
FIREBASE_SERVICE_ACCOUNT_B64=
